# Steward server configuration (ADR-0004). Copy to .env for local dev.
# The OAuth app's callback URL must be <origin>/auth/callback.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# openssl rand -hex 32
SESSION_SECRET=
# owner/name of the data-repo template
STEWARD_DATA_REPO_TEMPLATE=devord/steward-data-template
# prefix for per-user data repos (default shown)
STEWARD_DATA_REPO_PREFIX=steward-data-