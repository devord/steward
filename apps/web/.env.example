# Bulletin server configuration (ADR-0004). Copy to .env for local dev.
# The OAuth app's callback URL must be <origin>/auth/callback.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# openssl rand -hex 32
SESSION_SECRET=
# owner/name of the shared repo (catalog + contracts)
BULLETIN_SHARED_REPO=Form-Factory/bulletin
# owner/name of the data-repo template
BULLETIN_DATA_REPO_TEMPLATE=Form-Factory/bulletin-data-template
# prefix for per-user data repos (default shown)
BULLETIN_DATA_REPO_PREFIX=bulletin-data-

# `owner/name` of the org-owned team data repo (ADR-0010); unset = no team dashboards
BULLETIN_TEAM_REPO=Form-Factory/bulletin-data-team
