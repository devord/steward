{
  "name": "steward",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "vp check",
    "test": "turbo run test",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck && tsc -p scripts",
    "dev": "pnpm --filter @steward/web dev",
    "routine": "node packages/cli/src/cli.ts run",
    "routine:trigger": "node packages/cli/src/cli.ts trigger",
    "routines:sync": "node packages/cli/src/cli.ts sync",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm --filter @devord/steward build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@steward/schema": "workspace:*",
    "@types/node": "catalog:",
    "lefthook": "^1.13.0",
    "turbo": "^2.10.4",
    "typescript": "^7.0.2",
    "vite-plus": "^0.2.4",
    "yaml": "catalog:",
    "zod": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.17.1"
}
